# Copy to `.env` and adjust if needed. The harness also reads the process environment.

# Rust DB phases (bench-b3 … bench-b6)
DATABASE_URL=postgresql://bench:benchpassword@127.0.0.1:5433/benchmark

# Row count for generators / B0 loop
ROWS=1000000

# Paths (defaults match harness)
# BENCH_INPUT=bench/work/data.jsonl
# BENCH_OUTPUT=bench/work/data.jsonl
# BENCH_CACHE=bench/work/cache.bincode
# BENCH_OUTPUT_FINAL=bench/work/out.jsonl
